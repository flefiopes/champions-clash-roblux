# =============================================================================
# Backend API — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Variables without a value are REQUIRED; variables with a value show defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Levels: fatal, error, warn, info, debug, trace
LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log
LOG_ROTATION_FREQUENCY=daily
LOG_ROTATION_SIZE=10m
LOG_RETENTION_COUNT=14

# -----------------------------------------------------------------------------
# Database (MySQL)
# -----------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_CONNECTION_LIMIT=10

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=@@PASSWORD12345@@!

# -----------------------------------------------------------------------------
# Security (JWT)
# -----------------------------------------------------------------------------
# IMPORTANT: generate unique secrets for production
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET_ACCESS=change_me_access_secret
JWT_SECRET_REFRESH=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
COOKIE_MAX_AGE_DAYS=7


# -----------------------------------------------------------------------------
# Job Queue (BullMQ)
# -----------------------------------------------------------------------------
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_DELAY_MS=1000
JOB_REMOVE_ON_COMPLETE=100
JOB_REMOVE_ON_FAIL=50

# -----------------------------------------------------------------------------
# Workers
# -----------------------------------------------------------------------------
CRON_WORKER_CONCURRENCY=1
SAMPLE_WORKER_CONCURRENCY=2


# -----------------------------------------------------------------------------
# Rate Limiting
# Format: max requests / window seconds
# -----------------------------------------------------------------------------
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=60
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW=60
RATE_LIMIT_REFRESH_MAX=10
RATE_LIMIT_REFRESH_WINDOW=60

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173
