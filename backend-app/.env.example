# =============================================================================
# Champions Clash API — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Variables without a value are REQUIRED; variables with a value show defaults.
# =============================================================================

PORT=3000
NODE_ENV=development

LOG_LEVEL=debug
LOG_FILE_PATH=./logs/app.log
LOG_ROTATION_FREQUENCY=daily
LOG_ROTATION_SIZE=10m
LOG_RETENTION_COUNT=14

# -----------------------------------------------------------------------------
# Database (MySQL)
# -----------------------------------------------------------------------------
# En développement Docker, utilise localhost si tu lances le backend en dehors de Docker,
# mais dans le docker-compose, ces variables sont écrasées par DATABASE_HOST=mysql
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=champions_clash
DATABASE_CONNECTION_LIMIT=10

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Security — API Keys
# IMPORTANT: generate strong random secrets for production
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
ROBLOX_API_KEY=change_me_roblox_api_key
ADMIN_API_KEY=change_me_admin_api_key

# -----------------------------------------------------------------------------
# External Integrations
# -----------------------------------------------------------------------------
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# -----------------------------------------------------------------------------
# Job Queue (BullMQ) & Cron
# -----------------------------------------------------------------------------
JOB_MAX_ATTEMPTS=3
JOB_BACKOFF_DELAY_MS=1000
JOB_REMOVE_ON_COMPLETE=100
JOB_REMOVE_ON_FAIL=50
CRON_WORKER_CONCURRENCY=1

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_COIN_GAIN_MAX=20
RATE_LIMIT_COIN_GAIN_WINDOW=60
RATE_LIMIT_POINT_CONTRIB_MAX=30
RATE_LIMIT_POINT_CONTRIB_WINDOW=60
RATE_LIMIT_PURCHASE_MAX=10
RATE_LIMIT_PURCHASE_WINDOW=60
RATE_LIMIT_ADMIN_MAX=60
RATE_LIMIT_ADMIN_WINDOW=60

CORS_ORIGIN=*
