{
    "name": "template-api",
    "version": "0.0.1",
    "description": "Production-ready Elysia + Bun API template",
    "type": "module",
    "scripts": {
        "dev": "bun run --watch src/index.ts",
        "start": "NODE_ENV=production bun run src/index.ts",
        "test": "bun test",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write src/**/*.ts",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:studio": "drizzle-kit studio",
        "db:seed": "bun run scripts/seed.ts"
    },
    "dependencies": {
        "@elysiajs/cors": "^1.4.2",
        "@elysiajs/jwt": "^1.4.2",
        "@elysiajs/server-timing": "^1.4.1",
        "@elysiajs/swagger": "^1.3.1",
        "bullmq": "^5.76.8",
        "drizzle-orm": "^0.38.4",
        "elysia": "^1.4.28",
        "elysia-helmet": "^3.1.0",
        "elysia-ip": "^1.1.0",
        "ioredis": "^5.10.1",
        "mysql2": "^3.22.3",
        "pino": "^9.14.0",
        "pino-roll": "^4.0.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bun": "latest",
        "@types/node": "^25.7.0",
        "@types/nodemailer": "^7.0.11",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.3.0",
        "eslint-config-prettier": "^10.1.8",
        "jiti": "^2.7.0",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.3",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.3"
    }
}